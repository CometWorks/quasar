@inject FileBrowserService Browser

<MudDialog>
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
            <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Default" OnClick="Cancel" title="Cancel" />
            <MudText Typo="Typo.h6">@DialogTitle</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="2" Style="min-width: 480px;">
            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                <MudTextField @bind-Value="_currentPath"
                              Variant="Variant.Outlined"
                              Immediate="false"
                              Label="Path"
                              Class="mono flex-grow-1"
                              OnKeyDown="HandlePathKeyDownAsync"
                              OnAdornmentClick="Navigate"
                              Adornment="Adornment.End"
                              AdornmentIcon="@Icons.Material.Filled.Refresh" />
                <MudButton Variant="Variant.Outlined" OnClick="Navigate">Go</MudButton>
                <MudIconButton Icon="@Icons.Material.Filled.ArrowUpward" title="Up" OnClick="GoUp" />
            </MudStack>

            <MudCheckBox T="bool" Value="_showHidden" ValueChanged="HandleShowHiddenChanged" Label="Show hidden entries" Dense="true" />

            @if (_shortcuts.Count > 0)
            {
                <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                    @foreach (var shortcut in _shortcuts)
                    {
                        <MudChip T="string" Variant="Variant.Outlined" Size="Size.Small" OnClick="@(() => NavigateTo(shortcut.FullPath))">
                            @shortcut.Label
                        </MudChip>
                    }
                </MudStack>
            }

            <MudStack Row="true" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center" Spacing="0" Class="folder-picker-breadcrumbs">
                @foreach (var crumb in _breadcrumbs)
                {
                    var isCurrent = string.Equals(crumb.FullPath, _currentPath, StringComparison.OrdinalIgnoreCase);
                    <MudButton Variant="Variant.Text"
                               Size="Size.Small"
                               Disabled="@isCurrent"
                               Class="folder-picker-breadcrumb"
                               OnClick="@(() => NavigateTo(crumb.FullPath))">
                        @crumb.Label
                    </MudButton>
                }
            </MudStack>

            @if (!string.IsNullOrWhiteSpace(_error))
            {
                <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true">@_error</MudAlert>
            }
            else if (_xmlFiles.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
                    No XML manifests in this folder. Navigate into a folder that contains your plugin's manifest.
                </MudAlert>
            }

            <MudList T="string" Dense="true" Style="max-height: 320px; overflow-y: auto;">
                @foreach (var entry in _entries)
                {
                    <MudListItem T="string" OnClick="@(() => NavigateTo(entry.FullPath))">
                        <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                            <MudIcon Icon="@Icons.Material.Filled.Folder" Size="Size.Small" />
                            <MudText Typo="Typo.body2">@entry.Name</MudText>
                        </MudStack>
                    </MudListItem>
                }
                @foreach (var xml in _xmlFiles)
                {
                    var isSelected = string.Equals(xml.FullPath, _selectedXmlPath, StringComparison.OrdinalIgnoreCase);
                    <MudListItem T="string" OnClick="@(() => SelectXml(xml.FullPath))" Class="@(isSelected ? "mud-selected-item" : string.Empty)">
                        <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                            <MudIcon Icon="@Icons.Material.Filled.Description"
                                     Color="@(isSelected ? Color.Primary : Color.Default)"
                                     Size="Size.Small" />
                            <MudText Typo="Typo.body2">@xml.Name</MudText>
                            @if (isSelected)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">selected</MudChip>
                            }
                        </MudStack>
                    </MudListItem>
                }
            </MudList>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="Cancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   Disabled="@(string.IsNullOrWhiteSpace(_selectedXmlPath))"
                   OnClick="UseSelected">
            Use this manifest
        </MudButton>
    </DialogActions>
</MudDialog>

@code
{
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public string? InitialPath { get; set; }

    [Parameter]
    public string DialogTitle { get; set; } = "Pick plugin manifest";

    private string _currentPath = string.Empty;
    private string _error = string.Empty;
    private string _selectedXmlPath = string.Empty;
    private IReadOnlyList<FileBrowserEntry> _entries = Array.Empty<FileBrowserEntry>();
    private IReadOnlyList<FileBrowserFileEntry> _xmlFiles = Array.Empty<FileBrowserFileEntry>();
    private IReadOnlyList<FileBrowserBreadcrumb> _breadcrumbs = Array.Empty<FileBrowserBreadcrumb>();
    private IReadOnlyList<FileBrowserShortcut> _shortcuts = Array.Empty<FileBrowserShortcut>();
    private bool _showHidden;

    protected override void OnInitialized()
    {
        _shortcuts = Browser.GetShortcuts();
        var seed = string.IsNullOrWhiteSpace(InitialPath)
            ? Environment.GetFolderPath(Environment.SpecialFolder.UserProfile)
            : InitialPath;
        NavigateTo(seed);
    }

    private void NavigateTo(string path)
    {
        try
        {
            var resolved = FileBrowserService.ResolvePath(path);
            _entries = Browser.ListDirectories(resolved, _showHidden);
            _xmlFiles = Browser.ListXmlFiles(resolved, _showHidden);
            _breadcrumbs = FileBrowserService.GetBreadcrumbs(resolved);
            _currentPath = resolved;
            _selectedXmlPath = _xmlFiles.Count == 1 ? _xmlFiles[0].FullPath : string.Empty;
            _error = string.Empty;
        }
        catch (Exception exception)
        {
            _error = exception.Message;
        }
    }

    private void SelectXml(string fullPath) => _selectedXmlPath = fullPath;

    private void Navigate() => NavigateTo(_currentPath);

    private async Task HandlePathKeyDownAsync(KeyboardEventArgs args)
    {
        if (args.Key == "Enter")
            Navigate();

        await Task.CompletedTask;
    }

    private Task HandleShowHiddenChanged(bool value)
    {
        _showHidden = value;
        Navigate();
        return Task.CompletedTask;
    }

    private void GoUp()
    {
        var parent = Directory.GetParent(_currentPath);
        if (parent is not null)
            NavigateTo(parent.FullName);
    }

    private void Cancel() => MudDialog.Cancel();

    private void UseSelected()
    {
        if (!string.IsNullOrWhiteSpace(_selectedXmlPath))
            MudDialog.Close(DialogResult.Ok(_selectedXmlPath));
    }
}
