<MudCard Class="server-card">
    <MudCardHeader>
        <CardHeaderContent>
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                <MudText Typo="Typo.h6">@Agent.ServerDisplayName</MudText>
                <MudChip T="string" Size="Size.Small" Color="@(Agent.IsConnected ? Color.Success : Color.Error)">
                    @(Agent.IsConnected ? "connected" : "disconnected")
                </MudChip>
            </MudStack>
            <MudText Typo="Typo.caption">@Agent.NodeDisplayName · @Agent.WorldDisplayName</MudText>
            <MudText Typo="Typo.caption" Class="mono">@Agent.UniqueNameKey</MudText>
        </CardHeaderContent>
    </MudCardHeader>

    <MudCardContent>
        <ServerDetailPanel Agent="@Agent" />
    </MudCardContent>
</MudCard>

@code
{
    [Parameter, EditorRequired]
    public AgentRuntimeState Agent { get; set; } = default!;
}
