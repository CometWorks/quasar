@using MudBlazor.Utilities
@inherits LayoutComponentBase
@implements IDisposable
@inject ThemePreferenceService ThemePreference
@inject QuasarShutdownService ShutdownService
@inject WebServiceOptions WebServiceOptions
@inject BrandingService BrandingService
@inject QuasarUpdateService UpdateService
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@inject IDialogService DialogService

<MudThemeProvider Theme="@ThemePreference.Theme" IsDarkMode="@_isDarkMode" IsDarkModeChanged="OnSystemDarkModeChangedAsync" ObserveSystemDarkModeChange="@(_themeMode == ThemeMode.System)" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<BrandingHeadContent />

<MudLayout Style="@HoverPaletteStyle">
    <MudAppBar Elevation="0" Class="magnetar-appbar">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="ToggleDrawer" />
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="quasar-brand">
            <img class="quasar-brand-mark"
                 src="@LogoSrc"
                 alt="@($"{BrandingService.Settings.AppName} logo")" />
            <MudStack Spacing="0">
                <MudText Typo="Typo.h6">@BrandingService.Settings.AppName</MudText>
                <MudText Typo="Typo.caption" Class="magnetar-appbar-subtitle">@BrandingService.Settings.AppSubtitle</MudText>
            </MudStack>
        </MudStack>
        <MudSpacer />
        <MudTooltip Text="@GetUpdateBellTooltip()">
            <MudBadge Visible="@HasUpdateBellBadge" Color="Color.Warning" Dot="true" Overlap="true">
                <MudIconButton
                    Icon="@Icons.Material.Filled.Notifications"
                    Color="@GetUpdateBellColor()"
                    Href="/settings/updates" />
            </MudBadge>
        </MudTooltip>
        <MudMenu Icon="@GetThemeModeIcon()" Color="Color.Inherit" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight" Dense="true">
            <MudMenuItem Icon="@Icons.Material.Filled.BrightnessAuto" IconColor="@(_themeMode == ThemeMode.System ? Color.Primary : Color.Default)" OnClick="@(() => SetThemeModeAsync(ThemeMode.System))">System</MudMenuItem>
            <MudMenuItem Icon="@Icons.Material.Filled.LightMode" IconColor="@(_themeMode == ThemeMode.Light ? Color.Primary : Color.Default)" OnClick="@(() => SetThemeModeAsync(ThemeMode.Light))">Light</MudMenuItem>
            <MudMenuItem Icon="@Icons.Material.Filled.DarkMode" IconColor="@(_themeMode == ThemeMode.Dark ? Color.Primary : Color.Default)" OnClick="@(() => SetThemeModeAsync(ThemeMode.Dark))">Dark</MudMenuItem>
        </MudMenu>
        <AuthorizeView>
            <Authorized Context="authContext">
                <MudTooltip Text="@GetAuthTooltip(authContext.User)">
                    <MudIconButton
                        Icon="@Icons.Material.Filled.Logout"
                        Color="Color.Inherit"
                        Href="/logout" />
                </MudTooltip>
            </Authorized>
            <NotAuthorized>
                <MudTooltip Text="Sign in">
                    <MudIconButton
                        Icon="@Icons.Material.Filled.Login"
                        Color="Color.Inherit"
                        Href="/login" />
                </MudTooltip>
            </NotAuthorized>
        </AuthorizeView>
        <AuthorizeView Policy="@QuasarPolicyNames.CanShutdownQuasar">
            <Authorized>
                <MudTooltip Text="Quasar power actions">
                    <MudIconButton
                        Icon="@Icons.Material.Filled.PowerSettingsNew"
                        Color="Color.Error"
                        Disabled="@_isShuttingDown"
                        OnClick="HandlePowerClickAsync" />
                </MudTooltip>
            </Authorized>
        </AuthorizeView>
    </MudAppBar>

    <MudOverlay Visible="@_isShuttingDown" DarkBackground="true" AutoClose="false" ZIndex="9999">
        <MudStack AlignItems="AlignItems.Center" Spacing="4">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
            <MudText Typo="Typo.h6">@_shutdownStatus</MudText>
        </MudStack>
    </MudOverlay>

    <MudDrawer
        @bind-Open="_drawerOpen"
        Variant="DrawerVariant.Responsive"
        Breakpoint="Breakpoint.Md"
        ClipMode="DrawerClipMode.Always"
        Elevation="0"
        Width="180px"
        Class="magnetar-drawer">
        <NavMenu />
    </MudDrawer>

    <MudMainContent Class="magnetar-body">
        <MudContainer MaxWidth="MaxWidth.False" Class="magnetar-shell-content">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code
{
    private bool _drawerOpen = true;
    private bool _isDarkMode = true;
    private ThemeMode _themeMode = ThemeMode.System;
    private bool _isShuttingDown = false;
    private string _shutdownStatus = string.Empty;
    private string _lastUpdateNotice = string.Empty;
    private QuasarUpdateSnapshot _updateSnapshot = new();

    // The worker is restartable only when it was launched by the Quasar launcher, which
    // injects QUASAR_LAUNCHER_TOKEN (surfaced as WebServiceOptions.LauncherToken).
    // Standalone runs have no launcher to respawn the worker, so restart is disabled.
    private bool IsUnderBootstrap => !string.IsNullOrWhiteSpace(WebServiceOptions.LauncherToken);

    private string LogoSrc => _isDarkMode
        ? (BrandingService.Settings.LogoDarkPath ?? "/Quasar.png")
        : (BrandingService.Settings.LogoLightPath ?? "/Quasar-inverted-transparent.png");

    private string HoverPaletteStyle
    {
        get
        {
            var settings = BrandingService.Settings;
            var hoverPalette = _isDarkMode ? settings.DarkPalette : settings.LightPalette;
            var fallbackPalette = _isDarkMode ? ThemePalette.QuasarDark() : ThemePalette.QuasarLight();
            var background = NormalizeCssColor(hoverPalette.HoverBackground, fallbackPalette.HoverBackground);
            var text = NormalizeCssColor(hoverPalette.HoverContrastText, fallbackPalette.HoverContrastText);

            return $"--quasar-hover-list-background:{background};--quasar-hover-list-text:{text};";
        }
    }

    private static string NormalizeCssColor(string value, string fallback)
    {
        if (MudColor.TryParse(value, out var color))
            return color.ToString(MudColorOutputFormats.HexA);

        return MudColor.TryParse(fallback, out var fallbackColor)
            ? fallbackColor.ToString(MudColorOutputFormats.HexA)
            : fallback;
    }

    protected override void OnInitialized()
    {
        BrandingService.Changed += OnBrandingChanged;
        UpdateService.Changed += OnUpdatesChanged;
        _updateSnapshot = UpdateService.GetSnapshot();
    }

    public void Dispose()
    {
        BrandingService.Changed -= OnBrandingChanged;
        UpdateService.Changed -= OnUpdatesChanged;
    }

    private void OnBrandingChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private void OnUpdatesChanged()
    {
        var snapshot = UpdateService.GetSnapshot();
        _ = InvokeAsync(() =>
        {
            _updateSnapshot = snapshot;
            StateHasChanged();
        });

        var web = GetPrimaryWebUpdate(snapshot);
        var bootstrap = snapshot.Bootstrap;
        var noticeKey = $"{web?.Version}:{web?.IsStaged}:{bootstrap?.Version}";
        if (noticeKey == _lastUpdateNotice)
            return;

        _lastUpdateNotice = noticeKey;
        if (web is not null && web.IsStaged)
        {
            _ = InvokeAsync(() => Snackbar.Add($"Quasar UI {web.Version} is staged. Open Updates to activate.", Severity.Info));
            return;
        }

        if (web is not null)
        {
            _ = InvokeAsync(() => Snackbar.Add($"Quasar UI {web.Version} is ready to download.", Severity.Info));
            return;
        }

        if (bootstrap is not null)
            _ = InvokeAsync(() => Snackbar.Add($"Quasar launcher {bootstrap.Version} update available.", Severity.Info));
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        var (mode, isDark) = await ThemePreference.InitializeAsync();
        _themeMode = mode;
        _isDarkMode = isDark;
        await InvokeAsync(StateHasChanged);
    }

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }

    private async Task SetThemeModeAsync(ThemeMode mode)
    {
        await ThemePreference.SetModeAsync(mode);
        _themeMode = mode;
        _isDarkMode = ThemePreference.IsDarkMode;
    }

    private async Task OnSystemDarkModeChangedAsync(bool isDark)
    {
        _isDarkMode = isDark;
        ThemePreference.SyncSystemDarkMode(isDark);
        await InvokeAsync(StateHasChanged);
    }

    private string GetThemeModeIcon() => _themeMode switch
    {
        ThemeMode.Light => Icons.Material.Filled.LightMode,
        ThemeMode.Dark => Icons.Material.Filled.DarkMode,
        _ => Icons.Material.Filled.BrightnessAuto,
    };

    private bool HasUpdateBellBadge =>
        GetPrimaryWebUpdate(_updateSnapshot) is not null || _updateSnapshot.Bootstrap is not null;

    private Color GetUpdateBellColor() => HasUpdateBellBadge ? Color.Warning : Color.Inherit;

    private string GetUpdateBellTooltip()
    {
        var web = GetPrimaryWebUpdate(_updateSnapshot);
        if (web is not null)
            return web.IsStaged
                ? $"Quasar UI {web.Version} is staged. Open Updates to activate."
                : $"Quasar UI {web.Version} is ready to download.";

        if (_updateSnapshot.Bootstrap is not null)
            return $"Quasar launcher {_updateSnapshot.Bootstrap.Version} update available.";

        return "Updates";
    }

    private static QuasarUpdateCandidate? GetPrimaryWebUpdate(QuasarUpdateSnapshot snapshot) =>
        snapshot.WebReleases.FirstOrDefault(candidate => candidate.IsNewer && candidate.IsStaged) ??
        snapshot.WebReleases.FirstOrDefault(candidate => candidate.IsNewer);

    private static string GetAuthTooltip(System.Security.Claims.ClaimsPrincipal principal)
    {
        var displayName = principal.GetQuasarDisplayName();
        return string.IsNullOrWhiteSpace(displayName) ? "Sign out" : $"Sign out {displayName}";
    }

    private async Task HandlePowerClickAsync()
    {
        var parameters = new DialogParameters
        {
            [nameof(QuasarControlDialog.IsRestartAvailable)] = IsUnderBootstrap,
            [nameof(QuasarControlDialog.AgentOfflineShutdownSeconds)] = WebServiceOptions.AgentOfflineShutdownSeconds,
        };
        var options = new DialogOptions { CloseOnEscapeKey = true, FullWidth = true, MaxWidth = MaxWidth.Small };
        var dialog = await DialogService.ShowAsync<QuasarControlDialog>("Quasar power", parameters, options);
        var result = await dialog.Result;
        if (result is null || result.Canceled || result.Data is not QuasarControlAction action)
            return;

        switch (action)
        {
            case QuasarControlAction.RestartQuasar:
                await RestartQuasarAsync();
                break;
            case QuasarControlAction.ShutdownQuasar:
                await ShutdownQuasarAsync();
                break;
            case QuasarControlAction.ShutdownAllServers:
                ShutdownAllServers();
                break;
        }
    }

    private async Task RestartQuasarAsync()
    {
        _isShuttingDown = true;
        _shutdownStatus = "Restarting Quasar… the page will reload when it is back.";
        await InvokeAsync(StateHasChanged);

        // The worker is about to stop, dropping this Blazor circuit, so hand off to a
        // browser-side poller that reloads to the Dashboard once the new worker is
        // healthy. Invoke it before stopping so the call reaches the client in time.
        await JS.InvokeVoidAsync("quasarConfigs.reloadWhenHealthy", "/");

        ShutdownService.RestartWorker();
    }

    private async Task ShutdownQuasarAsync()
    {
        _isShuttingDown = true;
        _shutdownStatus = "Shutting down Quasar… running servers continue.";
        await InvokeAsync(StateHasChanged);
        ShutdownService.ShutdownQuasarPreservingServers();
    }

    private void ShutdownAllServers()
    {
        // Issue a stop on every running server — exactly as if Stop had been pressed on
        // each card. The servers wind down in the background and the Dashboard / Servers
        // list reflect their status, so there is no blocking overlay or status readout here.
        _ = ShutdownService.StopAllServersAsync(setGoalStateOff: true);
        Snackbar.Add("Server shutdown queued.", Severity.Info);
    }
}
