@inherits LayoutComponentBase
@inject ThemePreferenceService ThemePreference

<MudThemeProvider Theme="@ThemePreference.Theme" IsDarkMode="@_isDarkMode" ObserveSystemDarkModeChange="false" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="0" Class="magnetar-appbar">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="ToggleDrawer" />
        <MudStack Spacing="0">
            <MudText Typo="Typo.h6">Quasar</MudText>
            <MudText Typo="Typo.caption" Class="magnetar-appbar-subtitle">Supervisor control plane</MudText>
        </MudStack>
        <MudSpacer />
        <MudHidden Breakpoint="Breakpoint.SmAndDown">
            <MudChip T="string" Color="Color.Default" Variant="Variant.Outlined" Class="mr-2">
                Interactive Server
            </MudChip>
        </MudHidden>
        <MudTooltip Text="@(_isDarkMode ? "Switch to light mode" : "Switch to dark mode")">
            <MudIconButton
                Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                Color="Color.Inherit"
                OnClick="ToggleThemeAsync" />
        </MudTooltip>
    </MudAppBar>

    <MudDrawer
        @bind-Open="_drawerOpen"
        Variant="DrawerVariant.Responsive"
        Breakpoint="Breakpoint.Md"
        ClipMode="DrawerClipMode.Always"
        Elevation="0"
        Width="280px"
        Class="magnetar-drawer">
        <NavMenu />
    </MudDrawer>

    <MudMainContent Class="magnetar-body">
        <MudContainer MaxWidth="MaxWidth.False" Class="magnetar-shell-content">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code
{
    private bool _drawerOpen = true;
    private bool _isDarkMode = true;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        _isDarkMode = await ThemePreference.InitializeAsync();
        await InvokeAsync(StateHasChanged);
    }

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }

    private async Task ToggleThemeAsync()
    {
        _isDarkMode = !_isDarkMode;
        await ThemePreference.SetDarkModeAsync(_isDarkMode);
    }
}
